# ─── Supabase ───────────────────────────────────────────────
# Required. Set real values in .env.local and Netlify dashboard.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── App ────────────────────────────────────────────────────
# Canonical site URL for sitemap, OG metadata, and canonical links.
# In local dev: http://localhost:3000. In production: https://healthmadeclear.netlify.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Error Monitoring (optional) ───────────────────────────
# Sentry DSN for client-side error reporting (no PHI is sent).
# If not set, errors are logged to console only.
NEXT_PUBLIC_SENTRY_DSN=

# ─── Analytics (optional — configure before launch) ────────
# Google Analytics 4 measurement ID. If not set, analytics are no-ops.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Contact Form (optional) ───────────────────────────────
# Resend API key for sending contact form emails.
# If not set, submissions are stored in the contact_submissions Supabase table.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# Email address to receive contact form submissions.
# CONTACT_EMAIL=hello@healthmadeclear.com
