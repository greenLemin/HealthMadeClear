{
  "name": "health-made-clear",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/check-production-env.mjs && next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "content:generate-lessons": "tsx scripts/generate-lesson-mdx.ts",
    "content:bundle-lessons": "tsx scripts/bundle-lessons.ts",
    "content:generate-paths": "tsx scripts/generate-path-mdx.ts",
    "content:generate-glossary": "tsx scripts/generate-glossary-mdx.ts",
    "content:bundle-paths": "tsx scripts/bundle-paths.ts",
    "content:bundle-glossary": "tsx scripts/bundle-glossary.ts",
    "content:bundle": "npm run content:bundle-lessons && npm run content:bundle-paths && npm run content:bundle-glossary && npm run format",
    "content:validate": "tsx scripts/validate-content.ts",
    "test:coverage": "vitest run --coverage",
    "analyze": "ANALYZE=true next build",
    "prebuild": "npm run content:bundle"
  },
  "dependencies": {
    "@sentry/browser": "^9.15.0",
    "@swc/helpers": "^0.5.23",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.400.0",
    "next": "14.2.35",
    "next-intl": "^4.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.35",
    "@playwright/test": "^1.60.0",
    "@swc/helpers": "0.5.23",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.39",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.22.3",
    "typescript": "^5.5.3",
    "vitest": "^4.1.8"
  }
}
